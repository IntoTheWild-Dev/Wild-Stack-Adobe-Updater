// Wild Stack Updater — Debug build configuration
// Apply in Xcode: click package root → Build Settings → Configuration Files → Debug → choose this file

// ── Signing (no Apple Developer account required) ──────────────────────────
CODE_SIGN_STYLE = Manual
CODE_SIGN_IDENTITY = -
DEVELOPMENT_TEAM =
CODE_SIGNING_REQUIRED = YES
CODE_SIGNING_ALLOWED = YES

// ── Bundle identity (fixes all Sparkle "no CFBundleIdentifier" errors) ──────
PRODUCT_BUNDLE_IDENTIFIER = com.wildagency.WildStackUpdater
MARKETING_VERSION = 1.0.0
CURRENT_PROJECT_VERSION = 1

// ── Info.plist (contains SUFeedURL, SUPublicEDKey, LSMinimumSystemVersion) ──
INFOPLIST_FILE = Sources/WildStackUpdater/Resources/Info.plist
GENERATE_INFOPLIST_FILE = NO
